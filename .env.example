# ============================================================
# udra DAO — Core Lane deployment environment
# Copy to .env and fill in your values before running the script.
# All protocol parameters below match ProtocolConfig.sol defaults.
# Omit any line to use the default from ProtocolConfig.sol.
# ============================================================

# ---- Required -----------------------------------------------
PRIVATE_KEY=0xYOUR_PRIVATE_KEY
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_KEY
ETHERSCAN_API_KEY=YOUR_API_KEY

# ---- Token --------------------------------------------------
TOKEN_NAME=UDRA POWER
TOKEN_SYMBOL=UPT

# AccessControlDefaultAdminRules delay (seconds) — 3 days = 259200
ADMIN_TRANSFER_DELAY=259200

# ---- Earner -------------------------------------------------
# UPT minted per check-in (18 decimals) — 10 UPT = 10000000000000000000
CHECKIN_REWARD=10000000000000000000

# Max check-in UPT minted per epoch (18 decimals) — 5000 UPT
CHECKIN_GLOBAL_CAP=5000000000000000000000

# UPT minted per 0.01 ETH funded (18 decimals) — 100 UPT
FUND_REWARD_PER_UNIT=100000000000000000000

# Minimum ETH funding increment (wei) — 0.01 ETH
FUND_UNIT=10000000000000000

# Max fund UPT per user per epoch (18 decimals) — 1000 UPT
FUND_USER_CAP=1000000000000000000000

# Max fund UPT minted per epoch (18 decimals) — 10000 UPT
FUND_GLOBAL_CAP=10000000000000000000000

# Epoch duration in seconds — 1 day
EPOCH_LENGTH=86400

# ---- Governor -----------------------------------------------
# Timelock execution delay in seconds — 1 hour
TIMELOCK_DELAY=3600

# ---- Deployment -----------------------------------------------
# sepolia
CHAIN_ID=11155111